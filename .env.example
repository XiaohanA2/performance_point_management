# 环境配置示例文件
# 复制此文件为 .env 并根据实际情况填写配置

# 环境类型：production | test | development
NODE_ENV=development

# uniCloud 配置
# 生产环境
UNICLOUD_PRO_SPACE_ID=mp-5dcdd8dc-dc18-4559-9b2f-3c5e006c35b1
UNICLOUD_PRO_CLIENT_SECRET=8xsA/WX+h56zRsZ3dONlfA==

# 测试环境（需要在uniCloud控制台创建新空间）
UNICLOUD_TEST_SPACE_ID=your-test-space-id-here
UNICLOUD_TEST_CLIENT_SECRET=your-test-client-secret-here

# 开发环境（可选）
UNICLOUD_DEV_SPACE_ID=your-dev-space-id-here
UNICLOUD_DEV_CLIENT_SECRET=your-dev-client-secret-here

# API 环境标识（用于在代码中区分环境）
# production: 生产环境，正式数据
# test: 测试环境，测试数据
# development: 开发环境，本地调试
API_ENV=development

# 数据库前缀（可选，用于区分不同环境的集合）
# 生产环境不使用前缀，测试环境可以使用 test_ 前缀
DB_PREFIX=

# 调试模式
DEBUG=true

# 日志级别：error | warn | info | debug
LOG_LEVEL=debug
